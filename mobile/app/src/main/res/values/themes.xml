<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for the app (used before Compose takes over) -->
    <style name="Theme.Finlo" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.Finlo.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Finlo</item>
    </style>
</resources>
