# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  FINLO — Environment Variables Example                                   ║
# ║  Copy this to .env and replace all placeholders                          ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# 1. Supabase (https://app.supabase.com → Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# 2. Google OAuth (https://console.cloud.google.com → Credentials)
OAUTH_GOOGLE_CLIENT_ID=<google-oauth-client-id>
OAUTH_GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# 3. LLM / AI — Gemini free tier (https://ai.google.dev)
LLM_PROVIDER_KEY=<gemini-api-key>
LLM_PROVIDER_MODEL=gemini-2.0-flash
LLM_PROVIDER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_PROVIDER_KEY=<gemini-api-key>
EMBEDDING_PROVIDER_MODEL=text-embedding-004
EMBEDDING_PROVIDER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 4. Redis — Upstash free tier (https://upstash.com)
REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379

# 5. Object Storage
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=<storage-access-key>
STORAGE_SECRET_KEY=<storage-secret-key>
STORAGE_BUCKET=finance-receipts
STORAGE_REGION=us-east-1

# 6. Self-generated secrets
JWT_SECRET=<openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_MINUTES=10080
PII_ENCRYPTION_KEY=<python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
STORAGE_ENCRYPTION_KEY=<openssl rand -hex 32>

# 7. Monitoring (optional)
SENTRY_DSN=

# 8. App Config
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf
OTP_PROVIDER=mock
FEATURE_TRANSACTION_SYNC_EXPERIMENTAL=false
FEATURE_BANK_AGGREGATOR_CONNECT=false
FEATURE_EMAIL_STATEMENT_PARSE=false

# 9. Frontend (copy to frontend/.env)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
